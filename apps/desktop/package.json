{
  "name": "@ymshots/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "dev": "electron .",
    "build:main": "npx tsc -p tsconfig.node.json",
    "build:preload": "npx tsc -p tsconfig.preload.json",
    "build:renderer": "node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync(p.join('dist','renderer'),{recursive:true});fs.copyFileSync(p.join('..','..','site','public','app','index.html'),p.join('dist','renderer','index.html'));console.log('Renderer copied')\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "pack": "npm run build && npx electron-builder --config electron-builder.yml",
    "pack:win": "npm run build && npx electron-builder --config electron-builder.yml --win",
    "pack:mac": "npm run build && npx electron-builder --config electron-builder.yml --mac",
    "typecheck": "npx tsc --noEmit",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^28.3.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0"
  }
}
